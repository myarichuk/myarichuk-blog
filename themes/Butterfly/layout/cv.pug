  script.
    (function() {
      const rail = document.getElementById('hexRail');
      const height = window.innerHeight;
      const itemHeight = 14 + 14;
      const count = Math.floor(height / itemHeight) + 4;
      let addr = 0xA000;
      for (let i = 0; i < count; i++) {
        const el = document.createElement('div');
        el.className = 'hex-addr';
        el.textContent = '0x' + addr.toString(16).toUpperCase().padStart(4, '0');
        rail.appendChild(el);
        addr += 0x0013 + (i % 3 === 0 ? 0x0006 : 0);
      }
    })();
