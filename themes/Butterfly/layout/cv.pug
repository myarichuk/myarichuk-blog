extends includes/layout.pug

block content
  #page
    .hex-rail#hexRail

    main.cv-main
      // Header
      header
      .name Michael Yarichuk
      .title-line Senior Software Engineer &nbsp;·&nbsp; Systems &amp; Performance &nbsp;·&nbsp; .NET
      .contact-row
        a(href="mailto:michael.yarichuk@gmail.com") michael.yarichuk@gmail.com
        span +972-54-596-7649
        a(href="https://linkedin.com/in/myarichuk" target="_blank") linkedin.com/in/myarichuk
        a(href="https://github.com/myarichuk" target="_blank") github.com/myarichuk
        a(href="https://www.graymatterdeveloper.com" target="_blank") graymatterdeveloper.com

    // Two-column body
    .layout
      // Left: main content
      .content-main

        // Profile
        .section
          .section-label Profile
          p.profile-text
            | Senior software engineer and systems programmer with 13+ years of .NET experience,
            | specialising in high-performance and low-level engineering: zero-allocation patterns,
            | database storage internals, crash and core dump analysis, and memory subsystem design.
            | Spent seven years contributing to RavenDB and its Voron B-Tree storage engine at
            | Hibernating Rhinos. Builds production libraries benchmarked against hand-optimised baselines.
            | Autodidact since age&nbsp;12 — the kind who goes straight to the source: RBIL, processor manuals, WinDbg.

        // Experience
        .section
          .section-label Experience

          // Stealth Startup
          .entry
            .entry-header
              .entry-company Stealth Startup&nbsp;
                span(style="font-weight:400;color:var(--text-3);font-size:13px;") (Cybersecurity)
              .entry-period 2022 – present
            .entry-stack .NET 6/7/8 · C# · Docker · containerised microservices on-prem · Node.js
            .entry-note Company name and product details are NDA/MoD export-constrained. Listed as "stealth startup" on LinkedIn at company's request.

            .sub-phase Team Lead / Engineering Manager &nbsp;—&nbsp; 2022–2023
            ul
              li Managed a small agile team: goal-setting, KPIs, sprint planning, code reviews, and mentoring 3–4 engineers across .NET and Node.js stacks
              li Stayed hands-on throughout — no pure-management overhead; continued designing and shipping features in parallel
              li After ~1.5 years, transitioned to Tech Lead by mutual agreement — IC contribution was the higher-leverage use of time

            .sub-phase(style="margin-top:14px;") Tech Lead / Senior Backend Engineer &nbsp;—&nbsp; 2023–present
            ul
              li Technical lead for an on-premises containerised .NET microservice platform; responsible for architectural decisions, cross-service integration design, and performance strategy
              li Sole engineer with Node.js experience on the team — took full ownership of the Node.js service: feature development, maintenance, performance work, and production incidents
              li Post-mortem investigation of production
                strong hangs
                |  and
                strong managed memory leaks
                |  — including timer-queue-rooted
                code CancellationTokenSource
                |  leaks and finalizer-thread starvation — using WinDbg/SOS and memory heap snapshots
              li Triaged
                strong SELECT N+1
                |  issues across microservice boundaries; identified query fan-out patterns causing latency spikes under real production load
              li Established BenchmarkDotNet-based benchmarking culture; systematically identified and eliminated allocation hotspots in hot-path .NET services

          // Snyk
          .entry
            .entry-header
              .entry-company Snyk
              .entry-period 2021 – 2022
            .entry-role Senior Backend Software Developer
            .entry-stack TypeScript · Node.js · .NET · dependency graph analysis
            ul
              li Contributed to open-source dependency scanning across three language ecosystems:
                strong .NET
                |  (NuGet,
                code .csproj
                | /lock file resolution),
                strong Python
                |  (pip,
                code requirements.txt
                | , Poetry,
                code pyproject.toml
                | ), and
                strong Node.js
                |  (npm/yarn, transitive resolution)
              li Navigated and extended a large-scale legacy TypeScript codebase; maintained correctness of multi-layer dependency graph resolution logic under active feature development

          // Gigya/SAP
          .entry
            .entry-header
              .entry-company Gigya / SAP
              .entry-period 2020 – 2022
            .entry-role Senior Backend Software Developer
            .entry-stack .NET · C# · microservices · identity management at scale
            ul
              li Designed and built features across a high-volume microservice platform handling millions of identity events per day
              li Performance analysis and post-mortem investigation of production issues; full-stack work spanning backend services and internal tooling

          // Hibernating Rhinos
          .entry
            .entry-header
              .entry-company Hibernating Rhinos
              .entry-period 2013 – 2020
            .entry-role Server/Client Developer · Support Engineer
            .entry-stack .NET · C# · RavenDB · Voron B-Tree storage engine · LMDB · memory-mapped I/O
            ul
              li One of the longest-tenured engineers on the RavenDB core team —
                span.ach 7 years
                |  on a production NoSQL database and its storage engine
              li Implemented and maintained features in the
                strong Voron
                |  B-Tree storage engine: tree structure, transaction management, memory-mapped I/O, page management
              li Designed and built client-side and server-side API components across multiple RavenDB major versions; worked across the full stack from the wire protocol down to storage
              li Provided direct technical support to enterprise customers; diagnosed and resolved storage-layer bugs under production pressure

          // Early Career
          .entry
            .entry-header
              .entry-company Early Career
              .entry-period 2010 – 2013
            .entry-note(style="margin-top:4px;")
              | Junior developer roles including internal tooling and web development;
              | concurrent with intensive self-directed study in systems programming and .NET internals.

        // Education
        .section
          .section-label Education
          .edu-inst Technion – Israel Institute of Technology
          .edu-detail Physics B.Sc. &nbsp;·&nbsp; Attended ~4 semesters, did not complete &nbsp;·&nbsp; Left to work; family financial constraints
          .int13h
            strong Self-taught since ~age 12.
            br
            | 12th-grade final project: a fully self-implemented paint application in C++ under DOS —
            | trigonometry-based shape rendering,
            strong INT 10h, AX=0x0013
            |  (320×200, 256 colour),
            | writing pixels directly into VGA framebuffer memory at
            strong 0xA000:0000
            | .
            br
            | No libraries. No tutorials. Just Peter Norton's book, the RBIL, a compiler, and a lot of time.

        // Personal Projects
        .section
